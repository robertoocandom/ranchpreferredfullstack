# Google Sign-In (Google Identity Services) OAuth Client ID.
# Create one at https://console.cloud.google.com/apis/credentials
# (OAuth client type: "Web application"). Without this set, the app
# falls back to a demo sign-in button so it stays fully testable.
VITE_GOOGLE_CLIENT_ID=

# Base URL of the Ranch Preferred API (see ../server). Defaults to
# http://localhost:8787 for local development if unset.
VITE_API_URL=http://localhost:8787
